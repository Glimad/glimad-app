# ===========================================
# Glimad v0 — Environment Variables Template
# ===========================================
# Copy to .env.local and fill with real values.
# Variables marked "Backend only!" must NEVER be exposed to the browser.
# Only NEXT_PUBLIC_* variables are safe to expose to the client.

# ===========================================
# SUPABASE
# ===========================================
# Public: safe to expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# Backend only! (bypasses RLS — never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# Direct DB connection (optional, used by migration scripts)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ===========================================
# ANTHROPIC (Claude LLM)
# ===========================================
# Backend only!
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-5

# ===========================================
# STRIPE
# ===========================================
# Public: used by Stripe.js in checkout
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Backend only!
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (from Stripe Dashboard → Products)
STRIPE_PRICE_BASE=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ELITE=price_xxx

# ===========================================
# EMAIL (Resend)
# ===========================================
# Backend only!
RESEND_API_KEY=re_xxx
EMAIL_FROM=hola@glimad.com

# ===========================================
# N8N INTEGRATION
# ===========================================
# Backend only!
N8N_WEBHOOK_URL=https://n8n.example.com/webhook
N8N_API_KEY=n8n_api_xxx
# Generate: openssl rand -hex 32
N8N_WEBHOOK_SECRET=xxx

# ===========================================
# SCRAPING / DATA PROVIDERS
# ===========================================
# Backend only!
YOUTUBE_API_KEY=AIzaxxx
SPOTIFY_CLIENT_ID=xxx
SPOTIFY_CLIENT_SECRET=xxx
TWITTER_BEARER_TOKEN=xxx
# Optional: Apify for Instagram/TikTok
APIFY_API_TOKEN=apify_api_xxx

# ===========================================
# APP CONFIGURATION
# ===========================================
# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LOGO_URL=https://xxx.supabase.co/storage/v1/object/public/xxx/logo.png

# Backend only!
# Random string used to authenticate cron job requests
CRON_SECRET=your-random-cron-secret-here

# Default currency for Stripe checkout
DEFAULT_CURRENCY=EUR

# Admin email (gets is_admin=true on signup)
ADMIN_EMAIL=admin@glimad.com
